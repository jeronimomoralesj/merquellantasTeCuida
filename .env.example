# =============================================================================
# Merque Bienestar — Environment Variables
# Copy this to .env.local and fill in the values
# =============================================================================

# --- MongoDB ---
MONGODB_URI=mongodb+srv://user:password@cluster0.xxx.mongodb.net/?appName=Cluster0
MONGODB_DB=merque_bienestar

# --- NextAuth.js ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here
AUTH_TRUST_HOST=true

# --- Azure AD / Microsoft (for OneDrive & SharePoint) ---
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# --- OneDrive (Microsoft Graph API) ---
ONEDRIVE_OWNER=saludocupacional@merquellantas.com
ONEDRIVE_BASE_FOLDER=MerqueBienestar

# --- Gmail notifications ---
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# --- Gemini AI Chat ---
GEMINI_API_KEY=your-gemini-api-key
